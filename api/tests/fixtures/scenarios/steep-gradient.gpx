<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="test">
  <trk>
    <name>Steep Gradient Test</name>
    <trkseg>
      <!-- Flat approach -->
      <trkpt lat="45.000" lon="5.000"><ele>200</ele></trkpt>
      <trkpt lat="45.005" lon="5.000"><ele>200</ele></trkpt>
      <!-- Steep climb: ~555m per segment, +50m ele = ~9% gradient -->
      <trkpt lat="45.010" lon="5.000"><ele>250</ele></trkpt>
      <trkpt lat="45.015" lon="5.000"><ele>300</ele></trkpt>
      <trkpt lat="45.020" lon="5.000"><ele>350</ele></trkpt>
      <trkpt lat="45.025" lon="5.000"><ele>400</ele></trkpt>
      <trkpt lat="45.030" lon="5.000"><ele>450</ele></trkpt>
      <!-- Flat exit -->
      <trkpt lat="45.035" lon="5.000"><ele>450</ele></trkpt>
    </trkseg>
  </trk>
</gpx>

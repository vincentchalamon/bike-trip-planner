{
  "$schema": "https:\/\/json-schema.org\/draft-07\/schema#",
  "type": "object",
  "required": [
    "@context",
    "@id",
    "@type",
    "alerts",
    "pois",
    "accommodations",
    "trip",
    "dayNumber",
    "distance",
    "elevation",
    "elevationLoss",
    "startPoint",
    "endPoint",
    "geometry"
  ],
  "additionalProperties": false,
  "properties": {
    "@context": {
      "type": "string",
      "const": "/contexts/StageResponse"
    },
    "@id": {
      "type": "string",
      "pattern": "^/trips/.+/stages/\\d+$"
    },
    "@type": {
      "type": "string",
      "const": "StageResponse"
    },
    "label": {
      "type": "string"
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [],
        "additionalProperties": false,
        "properties": {}
      }
    },
    "pois": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [],
        "additionalProperties": false,
        "properties": {}
      }
    },
    "accommodations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [],
        "additionalProperties": false,
        "properties": {}
      }
    },
    "trip": {
      "type": "string",
      "pattern": "^/trips/.+$"
    },
    "dayNumber": {
      "type": "integer"
    },
    "distance": {
      "type": "number"
    },
    "elevation": {
      "type": "number"
    },
    "elevationLoss": {
      "type": "number"
    },
    "startPoint": {
      "type": "object",
      "required": [
        "@type",
        "@id",
        "lat",
        "lon",
        "ele"
      ],
      "additionalProperties": false,
      "properties": {
        "@type": {
          "type": "string",
          "const": "Coordinate"
        },
        "@id": {
          "type": "string",
          "pattern": "^/\\.well-known/genid/.+$"
        },
        "lat": {
          "type": "number"
        },
        "lon": {
          "type": "number"
        },
        "ele": {
          "type": "integer"
        }
      }
    },
    "endPoint": {
      "type": "object",
      "required": [
        "@type",
        "@id",
        "lat",
        "lon",
        "ele"
      ],
      "additionalProperties": false,
      "properties": {
        "@type": {
          "type": "string",
          "const": "Coordinate"
        },
        "@id": {
          "type": "string",
          "pattern": "^/\\.well-known/genid/.+$"
        },
        "lat": {
          "type": "number"
        },
        "lon": {
          "type": "number"
        },
        "ele": {
          "type": "integer"
        }
      }
    },
    "geometry": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "@type",
          "@id",
          "lat",
          "lon",
          "ele"
        ],
        "additionalProperties": false,
        "properties": {
          "@type": {
            "type": "string",
            "const": "Coordinate"
          },
          "@id": {
            "type": "string",
            "pattern": "^/\\.well-known/genid/.+$"
          },
          "lat": {
            "type": "number"
          },
          "lon": {
            "type": "number"
          },
          "ele": {
            "type": "integer"
          }
        }
      }
    }
  }
}

{
  "$schema": "https:\/\/json-schema.org\/draft-07\/schema#",
  "type": "object",
  "required": [
    "@context",
    "@id",
    "@type",
    "status",
    "violations",
    "detail",
    "title",
    "type",
    "description"
  ],
  "additionalProperties": false,
  "properties": {
    "@context": {
      "type": "string",
      "const": "/contexts/ConstraintViolation"
    },
    "@id": {
      "type": "string",
      "pattern": "^/validation_errors/.+$"
    },
    "@type": {
      "type": "string",
      "const": "ConstraintViolation"
    },
    "type": {
      "type": "string",
      "pattern": "^/validation_errors/.+$"
    },
    "title": {
      "type": "string"
    },
    "detail": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "integer"
    },
    "violations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "propertyPath",
          "message"
        ],
        "additionalProperties": false,
        "properties": {
          "propertyPath": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
